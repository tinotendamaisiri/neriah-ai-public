# NOTE: when .easignore exists, EAS uses it INSTEAD of .gitignore.
# Anything you want excluded from the upload must be listed here.

# Dependencies (EAS reinstalls from package.json)
node_modules/

# Native folders — regenerated by `expo prebuild` + postinstall on the builder
android/
ios/

# Local build artifacts
build-*.apk
*.apk
*.aab
*.ipa

# Expo / build output
.expo/
dist/

# On-device model bundles (downloaded at runtime, not shipped in the app)
assets/models/*.task
assets/models/*.litertlm

# Secrets / local env (re-add explicitly to EAS env if needed)
.env
.env.local
.env.*.local

# iOS vendored frameworks (EAS Android build doesn't need these)
vendor/litert-ios/
vendor/litert-cpp/
vendor/litert-podspec/

# Android local Maven repo (gets regenerated by install script)
vendor/litert-android-maven/

# Development and test files
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
.pytest_cache/
coverage/

# Logs / error dumps
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
patch-package-error.json.gz

# Backups
*.bak
app.json.bak

# Documentation
docs/
*.md
!README.md

# Sample files
samples/

# Git
.git/

# macOS
.DS_Store

# Editor
.vscode/
.idea/
.turbo/
tmp/
.tmp/
